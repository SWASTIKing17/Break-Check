						<string>var sourceTextProperty = thisComp.layer("Processed Text").text.sourceText;&#xD;var words = sourceTextProperty.split(" ").filter(function(word) { return word !== ''; });&#xD;var lineBreaks = sourceTextProperty.split("\r").filter(function(line) { return line !== ''; });&#xD;&#xD;var firstSplitPoint, secondSplitPoint;&#xD;&#xD;// Calculate first split point&#xD;if (lineBreaks.length &gt; 0) {&#xD;    firstSplitPoint = lineBreaks[0].trim().split(" ").filter(function(word) { return word !== ''; }).length;&#xD;} else {&#xD;    firstSplitPoint = words.length;&#xD;}&#xD;&#xD;// Calculate second split point&#xD;if (lineBreaks.length &gt; 1) {&#xD;    secondSplitPoint = lineBreaks[0].trim().split(" ").filter(function(word) { return word !== ''; }).length + lineBreaks[1].trim().split(" ").filter(function(word) { return word !== ''; }).length;&#xD;} else {&#xD;    secondSplitPoint = words.length;&#xD;}&#xD;&#xD;[firstSplitPoint, secondSplitPoint]&#xD;</string>
