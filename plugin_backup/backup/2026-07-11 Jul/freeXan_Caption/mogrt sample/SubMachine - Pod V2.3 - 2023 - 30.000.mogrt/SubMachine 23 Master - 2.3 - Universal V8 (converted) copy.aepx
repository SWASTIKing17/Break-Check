													<string>mainSourceText = thisComp.layer("Master Text").text.sourceText;&#xD;line1NumWords = thisComp.layer("Line 1").text.sourceText.trim().split(" ").length;&#xD;line2NumWords = thisComp.layer("Line 2").text.sourceText.trim().split(" ").length;&#xD;line3NumWords = thisComp.layer("Line 3").text.sourceText.trim().split(" ").length;&#xD;totalNumWords = line1NumWords + line2NumWords + line3NumWords;&#xD;thisLineStart = line1NumWords;&#xD;thisLineEnd = line1NumWords + line2NumWords;&#xD;if(thisComp.layer("Control").effect("Word Progression")("ADBE Slider Control-0001").value &gt;= thisLineStart || thisComp.layer("Control").effect("Word Progression")("ADBE Slider Control-0001").value &lt;= thisLineEnd){&#xD;&#x9;myValue = thisComp.layer("Control").effect("Word Progression")("ADBE Slider Control-0001").value +1 - line1NumWords;&#xD;}else{&#xD;&#x9;myValue = 0;&#xD;}&#xD;myValue</string>
