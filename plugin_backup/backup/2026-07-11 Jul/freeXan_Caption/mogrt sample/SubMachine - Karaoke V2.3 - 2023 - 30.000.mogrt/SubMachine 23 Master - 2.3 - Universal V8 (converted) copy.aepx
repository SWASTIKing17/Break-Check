												<string>line1NumWords = thisComp.layer("Line 1").text.sourceText.trim().split(" ").length;&#xD;line2NumWords = thisComp.layer("Line 2").text.sourceText.trim().split(" ").length;&#xD;line3NumWords = thisComp.layer("Line 3").text.sourceText.trim().split(" ").length;&#xD;if(thisComp.layer("Control").effect("Word Progression")("ADBE Slider Control-0001").value === line1NumWords + line2NumWords + 1){&#xD;&#x9;if(line3NumWords === 1){&#xD;&#x9;&#x9;x = thisComp.layer("Line 3").sourceRectAtTime().width - thisComp.layer("Line 3 Pre BG").content("Rectangle 1").content("Rectangle Path 1").size[0] - thisComp.layer("Line 3 Post BG").content("Rectangle 1").content("Rectangle Path 1").size[0] + thisComp.layer("Control").effect("Padding")("ADBE Slider Control-0001").value + (+thisComp.layer("Text Space Value").text.sourceText);&#xD;&#x9;}else{&#xD;&#x9;&#x9;x = thisComp.layer("Line 3").sourceRectAtTime().width - thisComp.layer("Line 3 Pre BG").content("Rectangle 1").content("Rectangle Path 1").size[0] - thisComp.layer("Line 3 Post BG").content("Rectangle 1").content("Rectangle Path 1").size[0] + thisComp.layer("Control").effect("Padding")("ADBE Slider Control-0001").value;&#xD;&#x9;}&#xD;}else if(thisComp.layer("Control").effect("Word Progression")("ADBE Slider Control-0001").value === line1NumWords + line2NumWords + line3NumWords){&#xD;&#x9;x = thisComp.layer("Line 3").sourceRectAtTime().width - thisComp.layer("Line 3 Pre BG").content("Rectangle 1").content("Rectangle Path 1").size[0] - thisComp.layer("Line 3 Post BG").content("Rectangle 1").content("Rectangle Path 1").size[0] + thisComp.layer("Control").effect("Padding")("ADBE Slider Control-0001").value;&#xD;}else{&#xD;&#x9;x = thisComp.layer("Line 3").sourceRectAtTime().width - thisComp.layer("Line 3 Pre BG").content("Rectangle 1").content("Rectangle Path 1").size[0] - thisComp.layer("Line 3 Post BG").content("Rectangle 1").content("Rectangle Path 1").size[0] + thisComp.layer("Control").effect("Padding")("ADBE Slid