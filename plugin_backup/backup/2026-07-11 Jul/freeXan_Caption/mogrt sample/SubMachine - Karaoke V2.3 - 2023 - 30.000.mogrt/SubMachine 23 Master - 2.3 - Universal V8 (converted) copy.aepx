										<cdat bdata="00000000"/>
										<string>var mainText = thisComp.layer("Master Text").text.sourceText;&#xD;var maxChars = thisComp.layer("Control").effect("Max Characters")("ADBE Slider Control-0001").value;&#xD;var manualBreaks = thisComp.layer("Control").effect("Manual Line Break")("ADBE Checkbox Control-0001").value;&#xD;&#xD;// Function to split text into lines with a max character limit&#xD;function splitText(text, maxCharsPerLine) {&#xD;    if (manualBreaks === 1) {&#xD;        // If manual line breaks are to be respected, return the text as is&#xD;        return text.split('\r');&#xD;    } else {&#xD;        // Split the text by spaces to get words&#xD;        var words = text.split(/\s+/);&#xD;        var lines = [];&#xD;        var currentLine = '';&#xD;&#xD;        words.forEach(function(word) {&#xD;            if ((currentLine + word).length &lt;= maxCharsPerLine) {&#xD;                currentLine += word + ' ';&#xD;            } else {&#xD;                if (currentLine.length &gt; 0) {&#xD;                    lines.push(currentLine.trim());&#xD;                    currentLine = '';&#xD;                }&#xD;                if (word.length &gt; maxCharsPerLine) {&#xD;                    lines.push(word); // Push the word itself if it's too long&#xD;                } else {&#xD;                    currentLine = word + ' ';&#xD;                }&#xD;            }&#xD;        });&#xD;&#xD;        if (currentLine.trim() !== '') {&#xD;            lines.push(currentLine.trim());&#xD;        }&#xD;        return lines;&#xD;    }&#xD;}&#xD;&#xD;// Initial split with or without respecting manual line breaks&#xD;var lines = splitText(mainText, maxChars);&#xD;&#xD;// Redistribute the text to fit into three lines if needed&#xD;if (lines.length &gt; 3 &amp;&amp; manualBreaks !== 1) {&#xD;    var totalChars = mainText.replace(/[\r\n]+/g, ' ').trim().length;&#xD;    var charsPerLine = Math.ceil(totalChars / 3);&#xD;    lines = splitText(mainText, charsPerLine);&#xD;    if (lines.length &gt; 3) {&#xD;        // Re-split text by forcing a split at the nearest space before overflow&#xD;        var charCount = 0;&#xD;        var lineStart = 0;&#xD;        lines = [];&#xD;        for (var i = 0; i &lt; totalChars; i++) {&#xD;            charCount++;&#xD;            if (charCount &gt;= charsPerLine || i === totalChars - 1) {&#xD;                var nextSpace = mainText.indexOf(' ', i);&#xD;                var end = nextSpace !== -1 ? nextSpace : totalChars;&#xD;                lines.push(mainText.slice(lineStart, end).trim());&#xD;                lineStart = end + 1;&#xD;                charCount = 0;&#xD;                i = end;&#xD;            }&#xD;        }&#xD;    }&#xD;}&#xD;&#xD;// Combine the lines with line breaks to form the processed text&#xD;var processedText = lines.join('\r').trim(); // Ensure no trailing spaces&#xD;processedText;&#xD;</string>
