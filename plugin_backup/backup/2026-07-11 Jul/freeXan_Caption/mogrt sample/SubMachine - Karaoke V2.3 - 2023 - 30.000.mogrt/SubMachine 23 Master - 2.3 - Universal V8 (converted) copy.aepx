											<string>// Get the value of the "Keep Bouncing" checkbox&#xD;keepBouncing = thisComp.layer("Control").effect("Keep Bouncing")("ADBE Checkbox Control-0001");&#xD;&#xD;// Get the value of the "Box Width" slider&#xD;boxWidthSlider = thisComp.layer("Control").effect("Box Width")("ADBE Slider Control-0001");&#xD;&#xD;if (keepBouncing == 1) {&#xD;  seedRandom(1, true);&#xD;  minVal = 98;&#xD;  maxVal = 105;&#xD;  oscillationSpeed = 12.5;&#xD;  randomness = 0.5;&#xD;&#xD;  widthOscillation = (maxVal - minVal) * (Math.sin(time * oscillationSpeed) * randomness + 1) / 2 + minVal + boxWidthSlider;&#xD;  heightOscillation = (maxVal - minVal) * (Math.sin(time * oscillationSpeed + Math.PI / 2) * randomness + 1) / 2 + minVal;&#xD;&#xD;  [widthOscillation, heightOscillation];&#xD;} else {&#xD;  [100 + boxWidthSlider, 100];&#xD;}&#xD;</string>
