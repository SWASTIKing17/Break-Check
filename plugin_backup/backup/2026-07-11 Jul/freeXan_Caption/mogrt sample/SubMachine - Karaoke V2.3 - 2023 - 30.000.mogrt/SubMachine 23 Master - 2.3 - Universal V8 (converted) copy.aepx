													<string>var checkboxOn = thisComp.layer("Control").effect("Highlight_SlideIn")("ADBE Checkbox Control-0001").value;&#xD;var timeToMove = 3 / 23.976; // Time in seconds it takes to move from -1 to 0&#xD;&#xD;if (checkboxOn == 1) {&#xD;    // Calculate progress of the movement. clamp it to the range [0, 1] so it doesn't overshoot&#xD;    var progress = Math.max(0, Math.min(1, (time - inPoint) / timeToMove));&#xD;    // Interpolate from -1 to 0 based on the progress&#xD;    var offset = linear(progress, 0, 1, -1, 0);&#xD;    offset;&#xD;} else {&#xD;    0; // when checkbox is off, set the value to 0 without any transition&#xD;}&#xD;</string>
