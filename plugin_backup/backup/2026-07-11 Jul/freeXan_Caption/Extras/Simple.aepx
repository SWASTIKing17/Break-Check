												<string>var fadeInDuration = 3; // Duration in frames to fade in&#xD;var frameDuration = thisComp.frameDuration; // Duration of a single frame in seconds&#xD;var startTime = thisLayer.inPoint; // When the layer starts&#xD;var currentTime = time - startTime; // Current time relative to the start of the layer&#xD;&#xD;var fadeInStartValue = 0; // Default starting opacity value&#xD;var fadeInEndValue = 100; // Target opacity value&#xD;&#xD;var advancedCheckbox = thisComp.layer("Checkbox Controls").effect("Advanced: Show Unspoken Words")("ADBE Checkbox Control-0001").value;&#xD;if (advancedCheckbox === 1) {&#xD;    fadeInStartValue = thisComp.layer("Text Layer").text.animator("Show Unspoken Words").property("Opacity").value;&#xD;}&#xD;&#xD;var opacity;&#xD;if (currentTime &lt; fadeInDuration * frameDuration) {&#xD;    opacity = linear(currentTime, 0, fadeInDuration * frameDuration, fadeInStartValue, fadeInEndValue);&#xD;} else {&#xD;    opacity = fadeInEndValue;&#xD;}&#xD;&#xD;opacity;&#xD;</string>
