													<string>var textLayer = thisLayer;&#xD;var enableExpression = thisComp.layer("Checkbox Controls").effect("Typewriter Pro - Enable")("ADBE Checkbox Control-0001").value;&#xD;var showUnspokenWords = thisComp.layer("Checkbox Controls").effect("Advanced: Show Unspoken Words")("ADBE Checkbox Control-0001").value;&#xD;var revealTimeSlider = thisComp.layer("Slider Controls").effect("Typewriter - Type Duration")("ADBE Slider Control-0001") * 0.1; // Multiply by 0.5 to make the effect faster&#xD;var alternateBehavior = thisComp.layer("Checkbox Controls").effect("Typewriter - Alternate Behavior")("ADBE Checkbox Control-0001").value;&#xD;var words = textLayer.text.sourceText.split(" ");&#xD;var wordProgression = Math.min(Math.floor(text.animator("Primary: Word Progression").selector("Range Selector 1").offset), words.length);&#xD;&#xD;if (enableExpression) {&#xD;  var endValue = 0;&#xD;  var currentWordLength = words[wordProgression - 1].length;&#xD;&#xD;  for (var i = 0; i &lt; wordProgression; i++) {&#xD;    endValue += words[i].length + (i &lt; wordProgression - 1 ? 1 : 0); // add 1 for space before all words except the last one&#xD;  }&#xD;&#xD;  if (showUnspokenWords &amp;&amp; !alternateBehavior) {&#xD;    var totalCharacters = textLayer.text.sourceText.length;&#xD;    endValue = totalCharacters;&#xD;  } else if (alternateBehavior) {&#xD;    // Alternate behavior&#xD;    var completion = Math.min((time - inPoint) / revealTimeSlider, 1);&#xD;    var currentWordStart = endValue - currentWordLength;&#xD;       var animatedEndValue = currentWordStart + (completion * currentWordLength) + 1; // Add 1 to stay one character ahead of the start value&#xD;    // Cap the animatedEndValue between the initial start value and the calculated end value&#xD;    animatedEndValue = Math.min(Math.max(animatedEndValue, currentWordStart + 1), endValue);&#xD;    endValue = animatedEndValue;&#xD;  }&#xD;&#xD;  endValue;&#xD;} else {&#xD;  value;&#xD;}&#xD;&#xD;</string>
