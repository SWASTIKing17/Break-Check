												<string>// Get the scale value from the Scale property in the Animator&#xD;var scale_value = text.animator("Text: Emphasized Word 2").property("Scale").value;&#xD;&#xD;// Get the value of the "Emphasis Tracking" Slider from the "Slider Controls" layer&#xD;var slider_value = thisComp.layer("Slider Controls").effect("Emphasis Tracking")("ADBE Slider Control-0001").value;&#xD;&#xD;// Set the base scale value at which the tracking should be normal (e.g., 100)&#xD;var base_scale = 100;&#xD;&#xD;// Set the base tracking value (e.g., 0)&#xD;var base_tracking = 0;&#xD;&#xD;// Calculate the average scale value&#xD;var average_scale = (scale_value[0] + scale_value[1]) / 2;&#xD;&#xD;// Calculate the ratio between the current scale and the base scale&#xD;var scale_ratio = average_scale / base_scale;&#xD;&#xD;// Calculate the tracking value based on the scale ratio&#xD;var tracking_value = base_tracking + (scale_ratio - 1) * 35;&#xD;&#xD;// Incorporate the slider value into the tracking value&#xD;var final_tracking_value = tracking_value + slider_value;&#xD;&#xD;final_tracking_value;&#xD;</string>
