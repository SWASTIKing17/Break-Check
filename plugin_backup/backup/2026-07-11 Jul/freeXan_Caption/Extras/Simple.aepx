													<string>var textLayer = thisLayer;&#xD;var enableExpression = thisComp.layer("Checkbox Controls").effect("Typewriter Pro - Enable")("ADBE Checkbox Control-0001").value;&#xD;var roundToggle = thisComp.layer("Checkbox Controls").effect("Typewriter - Round Values")("ADBE Checkbox Control-0001").value;&#xD;var revealTimeSlider = thisComp.layer("Slider Controls").effect("Typewriter - Type Duration")("ADBE Slider Control-0001") * 0.1; // Multiply by 0.5 to make the effect faster&#xD;var words = textLayer.text.sourceText.split(" ");&#xD;var wordProgression = Math.min(Math.floor(text.animator("Primary: Word Progression").selector("Range Selector 1").offset), words.length);&#xD;&#xD;if (enableExpression) {&#xD;  var startPercentage = 0;&#xD;  var currentWordLength = words[wordProgression - 1].length;&#xD;&#xD;  for (var i = 0; i &lt; wordProgression; i++) {&#xD;    startPercentage += words[i].length + (i &lt; wordProgression - 1 ? 1 : 0); // add 1 for space before all words except the last one&#xD;  }&#xD;&#xD;  var completion = Math.min((time - inPoint) / revealTimeSlider, 1);&#xD;&#xD;  // Alternate behavior&#xD;  var currentWordStart = startPercentage - currentWordLength;&#xD;  var animatedStartValue = currentWordStart + (completion * currentWordLength);&#xD;  // Apply Math.round if roundToggle is checked&#xD;  if (roundToggle) {&#xD;    animatedStartValue = Math.round(animatedStartValue);&#xD;  }&#xD;  // Cap the animatedStartValue between the initial start value and the calculated end value&#xD;  animatedStartValue = Math.min(Math.max(animatedStartValue, currentWordStart), startPercentage);&#xD;&#xD;  startPercentage = animatedStartValue;&#xD;&#xD;  startPercentage;&#xD;} else {&#xD;  value;&#xD;}&#xD;</string>
