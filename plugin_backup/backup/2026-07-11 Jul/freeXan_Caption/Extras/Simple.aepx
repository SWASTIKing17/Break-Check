											<string>// Read the "Override" checkbox value&#xD;override = thisComp.layer("Line Bending Null").effect("Override")("ADBE Checkbox Control-0001");&#xD;&#xD;if (override == 1) { // If the checkbox is not checked, execute the original code&#xD;    // Original code&#xD;    bsmth = (thisComp.layer("Line Bending Null").effect("Bend Smoothness")("ADBE Slider Control-0001"))&#xD;    blngth = (thisComp.layer("Line Bending Null").effect("Bend Length")("ADBE Slider Control-0001"))&#xD;    &#xD;    // Modify the inT1 and inT2 tangents to control the Bezier handles of the left and right points&#xD;    var inT1 = [-bsmth - blngth / 2, bsmth];&#xD;    var inT2 = [bsmth - blngth / 2, bsmth];&#xD;    &#xD;    c1 = thisComp.layer("Line Bending Null").effect("Left Point X")("ADBE Slider Control-0001")&#xD;    c2 = thisComp.layer("Line Bending Null").effect("Left Point Y Value")("ADBE Slider Control-0001")&#xD;    Ex = thisComp.layer("Line Bending Null").effect("Right Point X")("ADBE Slider Control-0001")&#xD;    Ey = thisComp.layer("Line Bending Null").effect("Right Point Y Position")("ADBE Slider Control-0001")&#xD;    &#xD;    // Get the "Path Width" slider value&#xD;    pathWidth = thisComp.layer("Line Bending Null").effect("Path Width")("ADBE Slider Control-0001");&#xD;&#xD;    // Apply the "Path Width" value to the left and right point X positions&#xD;    c1 -= pathWidth / 2;&#xD;    Ex += pathWidth / 2;&#xD;&#xD;    createPath(points = [[c1, c2], [Ex, Ey]], varinTangents = [inT1, inT2], varoutTangents = [inT1, inT2], isClosed = false)&#xD;} else { // If the checkbox is checked, return the text to its default position&#xD;    value&#xD;}</string>
