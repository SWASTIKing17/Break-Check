														<string>// Define the checkbox and slider controls&#xD;var checkboxControl = thisComp.layer("Checkbox Controls").effect("CW Transform Animate")("ADBE Checkbox Control-0001");&#xD;var durationSlider = thisComp.layer("Slider Controls").effect("CW Transform Duration")("ADBE Slider Control-0001") * 0.35;&#xD;var cycleEndlessly = thisComp.layer("Checkbox Controls").effect("Cycle endlessly")("ADBE Checkbox Control-0001");&#xD;var cwTransformToggle = thisComp.layer("Checkbox Controls").effect("CW Transform Toggle")("ADBE Checkbox Control-0001");&#xD;&#xD;// Check the status of the master toggle&#xD;if (cwTransformToggle == 0) {&#xD;    0; // Force the amount value to 0&#xD;} else {&#xD;    // Check the status of the checkbox&#xD;    if (checkboxControl == 1) {&#xD;        // Calculate the animation progress&#xD;        var progress;&#xD;        if (cycleEndlessly == 1) {&#xD;            progress = Math.abs(Math.sin(time / (durationSlider / 2) * Math.PI));&#xD;        } else {&#xD;            var singleCycleTime = Math.min(time, durationSlider / 2);&#xD;            progress = (time &lt;= durationSlider / 2) ? (Math.sin(singleCycleTime / (durationSlider / 2) * Math.PI)) : 0;&#xD;        }&#xD;&#xD;        // Interpolate the amount value from 0 to 100 and back to 0&#xD;        linear(progress, 0, 1, 0, 100);&#xD;    } else {&#xD;        100; // If the checkbox is not 1, set the amount to 100%&#xD;    }&#xD;}&#xD;</string>
