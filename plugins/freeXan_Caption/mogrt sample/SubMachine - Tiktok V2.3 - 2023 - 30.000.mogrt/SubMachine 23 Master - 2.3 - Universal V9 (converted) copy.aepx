										<string>// Get the checkbox value for "Use Custom BG"&#xD;var useCustomBG = thisComp.layer("CONTROL").effect("Use Custom BG")("ADBE Checkbox Control-0001").value;&#xD;&#xD;// Function to convert hex color to RGB&#xD;function hexToRgb(hex) {&#xD;  var r = parseInt(hex.substring(0,2), 16) / 255;&#xD;  var g = parseInt(hex.substring(2,4), 16) / 255;&#xD;  var b = parseInt(hex.substring(4,6), 16) / 255;&#xD;  return [r, g, b, 1]; // The fourth value, 1, represents full opacity in the RGBA color space&#xD;}&#xD;&#xD;// If the "Use Custom BG" checkbox is checked, use the custom color&#xD;if (useCustomBG == 1) {&#xD;    thisComp.layer("CONTROL").effect("Background Fill Colour")("ADBE Color Control-0001");&#xD;} else {&#xD;    // Otherwise, use the dropdown to determine the color&#xD;    var bgFillIndex = thisComp.layer("CONTROL").effect("Background Colour Selection")("Pseudo/@@7Af65TtORNWLOE9IseZSPQ-0001").value;&#xD;    switch (bgFillIndex) {&#xD;        case 1: &#xD;            thisComp.layer("CONTROL").effect("Background Fill Colour")("ADBE Color Control-0001"); // Custom&#xD;            break;&#xD;        case 2: &#xD;            hexToRgb("FFFFFF"); // White&#xD;            break;&#xD;        case 3: &#xD;            hexToRgb("000000"); // Black&#xD;            break;&#xD;        case 4: &#xD;            hexToRgb("D94E48"); // Red&#xD;            break;&#xD;        case 5: &#xD;            hexToRgb("F19750"); // Orange&#xD;            break;&#xD;        case 6: &#xD;            hexToRgb("EDCD5F"); // Yellow&#xD;            break;&#xD;        case 7: &#xD;            hexToRgb("89BF6A"); // Green&#xD;            break;&#xD;        case 8: &#xD;            hexToRgb("8AC5A8"); // Light Green&#xD;            break;&#xD;        case 9: &#xD;            hexToRgb("39513E"); // Dark Green&#xD;            break;&#xD;        case 10: &#xD;            hexToRgb("4E96E9"); // Blue&#xD;            break;&#xD;        case 11: &#xD;            hexToRgb("2846AC"); // Dark Blue&#xD;            break;&#xD;        case 12: &#xD;            hexToRgb("3D688A"); // Navy Blue&#xD;            break;&#xD;        case 13: &#xD;            hexToRgb("5559CD"); // Purple&#xD;            break;&#xD;        case 14: &#xD;            hexToRgb("F3D8E8"); // Light Pink&#xD;            break;&#xD;        case 15: &#xD;            hexToRgb("A08961"); // Brown&#xD;            break;&#xD;        case 16: &#xD;            hexToRgb("93979D"); // Grey&#xD;            break;&#xD;        case 17: &#xD;            hexToRgb("333333"); // Dark Grey&#xD;            break;&#xD;        case 18: &#xD;            thisComp.layer("CONTROL").effect("Color Control")("Color");&#xD;            break;&#xD;        default:  &#xD;            thisComp.layer("CONTROL").effect("Background Fill Colour")("ADBE Color Control-0001");&#xD;    }&#xD;}&#xD;</string>
