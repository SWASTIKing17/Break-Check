										<string>var processedText = thisComp.layer("Processed Text").text.sourceText;&#xD;var currentLine = 1; // For Line 1. Change this for other lines (2 for Line 2, etc.)&#xD;&#xD;function extractLine(text, lineNumber) {&#xD;    var lines = text.split(/[\r\n]+/); // Splits on manual and automatic line breaks&#xD;    return lines.length &gt;= lineNumber ? lines[lineNumber - 1] : "";&#xD;}&#xD;&#xD;var newStyle = processedText.getStyleAt(0,0); // Get the style of the first character&#xD;var lineText = extractLine(processedText, currentLine); // Extract specific line text&#xD;newStyle.setText(lineText); // Apply text to the layer&#xD;</string>
