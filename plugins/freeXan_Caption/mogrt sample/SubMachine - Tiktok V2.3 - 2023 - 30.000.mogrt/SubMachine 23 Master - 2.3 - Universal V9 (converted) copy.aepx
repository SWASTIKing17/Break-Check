										<string>var mainText = thisComp.layer("Main Text").text.sourceText;&#xD;var maxChars = thisComp.layer("CONTROL").effect("Max Characters Per Line")("ADBE Slider Control-0001").value;&#xD;&#xD;// A function to chunk the text into lines with a maximum character length&#xD;function chunkText(text, maxLen) {&#xD;  var result = [];&#xD;  var currentLine = '';&#xD;&#xD;  text.split(/\s+/).forEach(function(word) {&#xD;    if (currentLine.length + word.length + 1 &gt; maxLen) {&#xD;      result.push(currentLine.trim());&#xD;      currentLine = '';&#xD;    }&#xD;    currentLine += word + ' ';&#xD;  });&#xD;&#xD;  // Push the last line&#xD;  if (currentLine.length) {&#xD;    result.push(currentLine.trim());&#xD;  }&#xD;&#xD;  return result;&#xD;}&#xD;&#xD;// Get the style of the first character of the main text&#xD;var newStyle = mainText.getStyleAt(0,0);&#xD;&#xD;// Use chunkText function to split mainText into lines&#xD;var processedLines = chunkText(mainText, maxChars);&#xD;var processedTextWithBreaks = processedLines.join('\r');&#xD;&#xD;// Apply style to processed text with line breaks&#xD;newStyle.setText(processedTextWithBreaks);&#xD;</string>
