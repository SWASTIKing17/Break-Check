<?xml version="1.0" encoding="UTF-8"?>
<ExtensionManifest Version="5.0" ExtensionBundleId="com.bloomx.freexan.caption" ExtensionBundleVersion="1.0.0"
		ExtensionBundleName="freeXan Caption" xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance">
	<ExtensionList>
		<Extension Id="com.bloomx.freexan.caption.panel" Version="1.0.0" />
		<Extension Id="com.bloomx.freexan.caption.about" Version="1.0.0" />
	</ExtensionList>

	<ExecutionEnvironment>

		<HostList>
			<Host Name="AEFT" Version="[13.0,99.9]" />
			<Host Name="PPRO" Version="[9.1,99.9]" />
		</HostList>

		<LocaleList>
			<Locale Code="All" />
		</LocaleList>

		<RequiredRuntimeList>
			<RequiredRuntime Name="CSXS" Version="5.0" />
		</RequiredRuntimeList>

	</ExecutionEnvironment>

	<DispatchInfoList>

		<Extension Id="com.bloomx.freexan.caption.panel">
			<DispatchInfo >
				<Resources>
					<MainPath>./panel/panel.html</MainPath>
					<ScriptPath>./panel/jsx/main.jsx</ScriptPath>
					<CEFCommandLine>
					  <Parameter>--enable-nodejs</Parameter>
					  <Parameter>--allow-file-access-from-files</Parameter>
					  <Parameter>--allow-file-access</Parameter>
					</CEFCommandLine>
				</Resources>
				<Lifecycle>
					<AutoVisible>true</AutoVisible>
				</Lifecycle>
				<UI>
					<Type>Panel</Type>
					<Menu>freeXan Caption</Menu>
					<Geometry>
						<Size>
							<Height>300</Height>
							<Width>300</Width>
						</Size>
					</Geometry>
				</UI>
			</DispatchInfo>
		</Extension>

		<Extension Id="com.bloomx.freexan.caption.about">
			<DispatchInfo >
				<Resources>
					<MainPath>./dialog/dialog.html</MainPath>
					<CEFCommandLine>
					  <Parameter>--enable-nodejs</Parameter>
						<Parameter>--allow-file-access-from-files</Parameter>
					  <Parameter>--allow-file-access</Parameter>
					</CEFCommandLine>
				</Resources>
				<Lifecycle>
					<AutoVisible>true</AutoVisible>
				</Lifecycle>
				<UI>
					<Type>Modeless</Type>
					<Geometry>
						<Size>
							<Height>440</Height>
							<Width>350</Width>
						</Size>
						<MaxSize>
							<Height>500</Height>
							<Width>350</Width>
						</MaxSize>
						<MinSize>
							<Height>100</Height>
							<Width>350</Width>
						</MinSize>
					</Geometry>
				</UI>
			</DispatchInfo>
		</Extension>
	</DispatchInfoList>
</ExtensionManifest>
